# Copy to .env and fill in. Never commit real values.

# Database (default: SQLite file in backend/)
# DATABASE_URL=sqlite:///./esoccer.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/esoccer

# BetsAPI provider (backend/app/connectors/betsapi_provider.py)
# Get the token from betsapi.com Orders page after purchase.
# Either var name works; BETSAPI_KEY is checked first.
BETSAPI_KEY=

# Alert webhooks can also be set in the UI (Settings page);
# env vars are not required for them.
